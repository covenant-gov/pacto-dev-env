# Pacto dev environment — copy this file to `.env` and override the secrets
# before running the `bunker` or `full` profiles.
#
# WARNING: The default values below are insecure placeholders. Generate real
# secrets and put them in `.env`.
#
# Docker Compose automatically loads `.env` when it exists in this directory.
# All variables are optional unless otherwise noted; sensible defaults are
# provided in docker-compose.yml and the scripts.

# ---------------------------------------------------------------------------
# General development options
# ---------------------------------------------------------------------------

# Path to the sibling `pacto-gov` repository. The `seed` and `seed-squad` targets
# need this. Defaults to the sibling directory `../pacto-gov`.
# PACTO_GOV_DIR=/home/you/src/covenant-gov/pacto-gov

# Force the governance contract seeder to re-deploy even when a deployment
# artifact already exists. Set to 1 for a clean re-deploy.
FORCE_SEED=0

# ---------------------------------------------------------------------------
# pacto-bot-api default identity (optional)
# ---------------------------------------------------------------------------

# If both are set, `make config` will generate a pacto-bot-api.toml with a
# default bot identity. Set PACTO_CREATE_DEV_BOT=1 to append an identity named
# "dev" instead. Leave empty or unset to start the daemon with no bots and add
# identities later with `pacto-bot-admin`.
# PACTO_CREATE_DEV_BOT=1
# PACTO_BOT_NPUB=npub1...
# PACTO_BOT_NSEC=nsec1...

# ---------------------------------------------------------------------------
# NIP-46 bunker secrets (required for `--profile bunker` or `full`)
# ---------------------------------------------------------------------------

JWT_SECRET=changeme-jwt-secret-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=changeme-refresh-secret-must-be-at-least-32-characters-long
ENCRYPTION_KEY=changeme-encryption-key-must-be-at-least-32-characters-long

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:8080
# Set to true when running the bunker behind HTTPS so cookies get the Secure flag.
COOKIE_SECURE=
LOG_LEVEL=info
ALLOW_REGISTRATION=false
NOSTR_DEFAULT_RELAYS=

# ---------------------------------------------------------------------------
# Squad seeding options (`make seed-squad`)
# ---------------------------------------------------------------------------

# Required by `make seed-squad` to create an identity-aware Nave Pirata squad.
# These are the Nostr public keys (hex or npub) of the captain and a candidate
# crew member. Generate them with `pacto-bot-admin new <name> --backend nsec
# --relays ws://localhost:7000`.
# If the env vars below are missing, `make seed-squad` can auto-create the
# identities inside the pacto-bot-api container and append them to
# pacto-bot-api.toml. Set PACTO_AUTO_CREATE_SQUAD_IDENTITIES=1 to skip the prompt.
# PACTO_AUTO_CREATE_SQUAD_IDENTITIES=1
# PACTO_SQUAD_CAPTAIN_NPUB=npub1...
# PACTO_SQUAD_CANDIDATE_NPUB=npub1...

# Optional: custom bot id names for the captain and candidate identities.
# PACTO_SQUAD_CAPTAIN_BOT_ID=captain
# PACTO_SQUAD_CANDIDATE_BOT_ID=candidate

# Optional: metadata URI for the squad deployment. Defaults to a dummy IPFS URI
# for local testing.
# PACTO_SQUAD_METADATA_URI=ipfs://Qmdummy

# Optional: control how crew members are created by `make seed-squad`.
# By default the script creates crew bot identities (crew-1, crew-2, ...)
# with pacto-bot-admin, derives their Ethereum addresses from their nsec
# values, and bootstraps them on-chain.
# PACTO_SQUAD_CREW_COUNT=3
# Or use specific bot ids instead of the default crew-N names:
# PACTO_SQUAD_CREW_BOT_IDS=crew-1,crew-2,candidate
# Or provide explicit ETH addresses (comma-separated) and skip bot creation:
# PACTO_SQUAD_CREW_ADDRESSES=0x...,0x...

# ---------------------------------------------------------------------------
# Advanced / rarely changed
# ---------------------------------------------------------------------------

# Anvil JSON-RPC endpoint and deployer key. You usually do not need to change
# these for local development.
# ANVIL_RPC_URL=http://localhost:8545
# ANVIL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Setup-script behavior. Set PACTO_SKIP_AZTEC_CLI=1 to skip the Aztec sandbox
# version manager installation. Set PACTO_CLONE_REPOS=skip to skip the repo
# cloning prompt in non-interactive environments.
# PACTO_SKIP_AZTEC_CLI=0
# PACTO_CLONE_REPOS=

# Non-interactive mode for `make up-all` / `make seed` when the sibling repo is
# missing. Set YES=1 to auto-clone and install without prompting.
# YES=0

# Force the squad seeder to re-deploy even when a squad artifact already exists.
# Set to 1 for a clean re-deploy.
# FORCE_SEED_SQUAD=0

# Override the bytecode directory used by `scripts/ensure-external-contracts.sh`.
# You usually do not need to change this.
# PACTO_BYTECODE_DIR=./scripts/bytecode

# Override paths used by `scripts/verify-squad.sh`.
# PACTO_SQUAD_ARTIFACT=./data/deployments/31337/squad.json
# PACTO_GOV_ARTIFACT=./data/deployments/31337/full-system.json
# PACTO_SQUAD_CANDIDATE_ADDRESS=0x...
