# Pacto dev environment — copy this file to `.env` and override the secrets
# before running the `bunker` or `full` profiles.
#
# WARNING: The default values below are insecure placeholders. Generate real
# secrets and put them in `.env`.

JWT_SECRET=changeme-jwt-secret-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=changeme-refresh-secret-must-be-at-least-32-characters-long
ENCRYPTION_KEY=changeme-encryption-key-must-be-at-least-32-characters-long

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:8080
LOG_LEVEL=info
ALLOW_REGISTRATION=false
NOSTR_DEFAULT_RELAYS=
