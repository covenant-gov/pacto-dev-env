# Pacto dev environment — copy this file to `.env` and override the secrets
# before running the `bunker` or `full` profiles.
#
# WARNING: The default values below are insecure placeholders. Generate real
# secrets and put them in `.env`.

JWT_SECRET=changeme-jwt-secret-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=changeme-refresh-secret-must-be-at-least-32-characters-long
ENCRYPTION_KEY=changeme-encryption-key-must-be-at-least-32-characters-long

# Pacto bot API default signing key (optional). If both are set, `make config`
# will generate a pacto-bot-api.toml with a default bot identity. Set
# PACTO_CREATE_DEV_BOT=1 to append an identity named "dev" instead.
# Leave empty or unset to start the daemon with no bots and add identities later
# with `pacto-bot-admin`.
# PACTO_CREATE_DEV_BOT=1
# PACTO_BOT_NPUB=npub1...
# PACTO_BOT_NSEC=nsec1...

# Required by `make seed-squad` to create an identity-aware Nave Pirata squad.
# These are the Nostr public keys (hex or npub) of the captain and a candidate
# crew member. Generate them with `pacto-bot-admin new <name> --backend nsec
# --relays ws://localhost:7000`.
# PACTO_SQUAD_CAPTAIN_NPUB=npub1...
# PACTO_SQUAD_CANDIDATE_NPUB=npub1...

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:8080
LOG_LEVEL=info
ALLOW_REGISTRATION=false
NOSTR_DEFAULT_RELAYS=
