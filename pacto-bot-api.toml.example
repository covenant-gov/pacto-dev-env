# Example pacto-bot-api.toml for the pacto-dev-env compose stack.
# Copy this file to `pacto-bot-api.toml`, set mode 0o600, and add real bot
# identities (e.g. by running `pacto-bot-admin`).
#
# WARNING: This file contains signing material. Never commit the real file.

[daemon]
data_dir = "/var/lib/pacto-bot-api"
socket_path = "/var/lib/pacto-bot-api/pacto-bot-api.sock"

# Add one or more bot identities below. For example:
#
# [[bots]]
# id = "bosun"
# npub = "npub1..."
# signing = { backend = "nsec", nsec = "${PACTO_BOT_NSEC}" }
# relays = ["ws://nostr-relay:8080"]
# capabilities = ["ReadMessages", "SendMessages"]
